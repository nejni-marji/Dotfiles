#
# ~/.config/sway/config
#
# vim: et ts=4 sw=4

### TABLE OF CONTENTS
#   * Variables
#   * Autostart
#   * Includes
#   * Graphical configuration
#     * Themeing
#     * Window rules
#   * Input configuration
#   * Key bindings
#     * Basics
#     * Movement
#     * Workspace bindings
#       * Workspace configs
#     * Layout bindings
#     * Resizing
#   * Application bindings
#   * Utilities
#   * Status bar



#
### Variables
#
    # modifier keys
    set $mod Mod4
    set $alt Mod1
    set $ctl Ctrl
    set $shf Shift
    set $float space
    # direction keys
    set $left h
    set $down t
    set $up n
    set $right s
    # preferred executables
    set $term foot
    set $menu wmenu-run -i -l 15 -f '$font' -p 'Run:' -M ff8cda -m 000000 -N 8cdaff -n 000000 -S ff8cda -s 000000
    set $menu_alt i3-dmenu-desktop --dmenu='wmenu -i -l 15 -f "$font" -p Run: -M ff8cda -m 000000 -N 8cdaff -n 000000 -S ff8cda -s 000000'
    # wallpapers
    set $wallpaper  ~/.local/share/wallpapers/wallpaper
    set $lockscreen ~/.local/share/wallpapers/lockscreen

    # include
    include ~/.config/sway/config.d/host-include
    include ~/Dotfiles/extras/secrets/sway-secrets

#
### Autostart
#
    # idle configuration aka powersaving aka screenlock
    # turn off monitors after 10 minutes, wait 30 seconds to lock, wait 5 minutes to sleep
    exec swayidle -w \
        timeout 600 'swaymsg "output * dpms off"' \
        timeout 630 'swaylock -f -i $lockscreen' \
        resume 'swaymsg "output * dpms on"' \
        before-sleep 'swaylock -f -i $lockscreen'

    # idle inhibitor for gaming and movies
    for_window [all] inhibit_idle fullscreen

    # this is stupid. but it works
    exec dbus-update-activation-environment --systemd GDK_BACKEND=wayland XDG_CURRENT_DESKTOP=sway WAYLAND_DISPLAY

    # screen dimming now handled in i3blocks

    # notification server
    exec mako

    # titlebar icons
    exec ~/.cargo/bin/swaycons

#
### Graphical configuration
#
    # set wallpapers
    output * bg $wallpaper fill

    # font
    font pango:$font

    # colors
    # client.class             outline   bckgrnd   frgrnd    indctr    border
    client.focused             #e667be   #ff8cda   #000000   #8cdaff   #ff8cda
    client.focused_inactive    #666666   #5f676a   #ffffff   #484e50   #5f676a
    client.focused_tab_title   #666666   #5f676a   #ffffff   #484e50   #5f676a
    client.unfocused           #666666   #222222   #888888   #292d2e   #222222
    client.urgent              #ff9933   #ffc68c   #000000   #8cdaff   #ffc68c

    # borders
    default_border $border
    default_floating_border $border
    hide_edge_borders $hide_edge_borders
    exec_always swaymsg '[all] border $border'

    # configure gaps
    smart_gaps inverse_outer
    gaps inner $gaps_inner
    gaps outer $gaps_outer

    # sway ux settings
    title_align center
    titlebar_padding 30 4
    force_display_urgency_hint 500
    focus_wrapping no

    # assign apps to workspaces
    assign [app_id="^[Dd]iscord$"] workspace $ws1
    assign [app_id="^[Ss]ignal$"]  workspace $ws1
    assign [class="^[Ss]team$"]    workspace $ws4

    # window rules
    for_window [title="^Open Files$"] floating enable
    for_window [title="^Open Files$"] resize set width 50 ppt height 80 ppt
    for_window [title="^Open Files$"] move position center

    for_window [app_id="^org\.pulseaudio\.pavucontrol$"] floating enable
    for_window [app_id="^org\.pulseaudio\.pavucontrol$"] resize set width 50 ppt height 80 ppt
    for_window [app_id="^org\.pulseaudio\.pavucontrol$"] move position center

    for_window [class="^[Ss]team$" title="^Steam Settings$"] floating enable
    for_window [class="^[Ss]team$" title="^Steam Settings$"] border $border

    for_window [class="^[Ss]team$" title="Friends List"] floating enable
    for_window [class="^[Ss]team$" title="Friends List"] border $border
    for_window [class="^[Ss]team$" title="Friends List"] resize set width 284 px height 75 ppt
    for_window [class="^[Ss]team$" title="Friends List"] move position 80 ppt 10 ppt

    # scratchpad window rules
    for_window [title="^pulsemixer$"] mark vol
    for_window [con_mark="^vol$"] floating enable
    for_window [con_mark="^vol$"] move scratchpad
    for_window [con_mark="^vol$"] scratchpad show
    for_window [con_mark="^vol$"] resize set width 50 ppt height 80 ppt
    for_window [con_mark="^vol$"] move position center

    for_window [app_id="^blueman-manager$"] mark bt
    for_window [con_mark="^bt$"] floating enable
    for_window [con_mark="^bt$"] move scratchpad
    for_window [con_mark="^bt$"] scratchpad show
    for_window [con_mark="^bt$"] resize set width 50 ppt height 80 ppt
    for_window [con_mark="^bt$"] move position center

    for_window [title="mynoise\.net"] mark mynoise
    for_window [con_mark="^mynoise$"] floating enable
    for_window [con_mark="^mynoise$"] border $border
    for_window [con_mark="^mynoise$"] move scratchpad
    for_window [con_mark="^mynoise$"] scratchpad show
    for_window [con_mark="^mynoise$"] resize set width 50 ppt height 80 ppt
    for_window [con_mark="^mynoise$"] move position center

#
### Input configuration
#
    input type:keyboard {
        xkb_layout us
        xkb_variant dvorak
        xkb_options compose:ralt
    }

    input type:pointer {
        accel_profile adaptive
        pointer_accel -0.35
    }

    input type:touchpad {
        tap enabled
        scroll_method two_finger
        drag_lock enabled_sticky
    }

    seat * {
        xcursor_theme $cursor
        hide_cursor 5000
    }

#
### Key bindings
#
    # start a terminal
    bindsym $mod+Return exec $term
    bindsym $mod+$shf+Return exec $term -T - sleep infinity
    bindsym $mod+$alt+Return exec $term -T - watch -tw -n60 'echo ${COLUMNS}x${LINES} ; echo ${COLUMNS}x${LINES} | figlet -k'

    # kill focused window
    bindsym $mod+$shf+q kill

    # app launchers
    bindsym $alt+Space  exec $menu
    bindsym $mod+d      exec $menu
    bindsym $mod+$shf+d exec $menu_alt
    bindsym $mod+$ctl+d exec ~/.config/sway/bin/wmenu-windows.sh

    # reload the configuration file
    bindsym $mod+$shf+c reload

    # floating windows
    floating_modifier $mod normal
    bindsym $mod+$shf+$float floating toggle, border $border
    bindsym $mod+$float focus mode_toggle
    bindsym $mod+$ctl+$float sticky toggle
    # TODO: make this check if the focused window is floating
    bindsym $mod+$shf+m resize set width 50 ppt height 80 ppt, move position center

    # exit sway (logs you out of your wayland session)
    bindsym $mod+$shf+e exec swaynag -t warning \
        -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' \
        -B 'Yes, exit sway' 'swaymsg exit'

    # lock sway manually
    bindsym $ctl+$alt+l exec swaylock -f -i $lockscreen
    bindsym $mod+$ctl+l exec swaylock -f -i $lockscreen


#
# Moving around:
#
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    bindsym $mod+$shf+$left move left
    bindsym $mod+$shf+$down move down
    bindsym $mod+$shf+$up move up
    bindsym $mod+$shf+$right move right
    bindsym $mod+$shf+Left move left
    bindsym $mod+$shf+Down move down
    bindsym $mod+$shf+Up move up
    bindsym $mod+$shf+Right move right

    bindsym $mod+$ctl+$left   fullscreen disable; focus left; fullscreen enable
    bindsym $mod+$ctl+$down   fullscreen disable; focus down; fullscreen enable
    bindsym $mod+$ctl+$up     fullscreen disable; focus up; fullscreen enable
    bindsym $mod+$ctl+$right  fullscreen disable; focus right; fullscreen enable
    bindsym $mod+$ctl+Left    fullscreen disable; focus left; fullscreen enable
    bindsym $mod+$ctl+Down    fullscreen disable; focus down; fullscreen enable
    bindsym $mod+$ctl+Up      fullscreen disable; focus up; fullscreen enable
    bindsym $mod+$ctl+Right   fullscreen disable; focus right; fullscreen enable

    # select most regent urgent container
    bindsym $mod+m [urgent=latest] focus

#
# Workspaces:
#
    # workspace options
    workspace_auto_back_and_forth yes

    # move by number
    bindsym $mod+1 workspace number $ws1
    bindsym $mod+2 workspace number $ws2
    bindsym $mod+3 workspace number $ws3
    bindsym $mod+4 workspace number $ws4
    bindsym $mod+5 workspace number $ws5
    bindsym $mod+6 workspace number $ws6
    bindsym $mod+7 workspace number $ws7
    bindsym $mod+8 workspace number $ws8
    bindsym $mod+9 workspace number $ws9
    bindsym $mod+0 workspace number $ws0
    bindsym $mod+$shf+1 move container to workspace number $ws1
    bindsym $mod+$shf+2 move container to workspace number $ws2
    bindsym $mod+$shf+3 move container to workspace number $ws3
    bindsym $mod+$shf+4 move container to workspace number $ws4
    bindsym $mod+$shf+5 move container to workspace number $ws5
    bindsym $mod+$shf+6 move container to workspace number $ws6
    bindsym $mod+$shf+7 move container to workspace number $ws7
    bindsym $mod+$shf+8 move container to workspace number $ws8
    bindsym $mod+$shf+9 move container to workspace number $ws9
    bindsym $mod+$shf+0 move container to workspace number $ws0

    # move between workspaces and outputs
    bindsym $mod+bracketleft workspace prev_on_output
    bindsym $mod+bracketright workspace next_on_output
    bindsym $mod+BackSpace workspace back_and_forth
    bindsym $mod+$shf+BackSpace move container to workspace back_and_forth
    bindsym $alt+Tab exec swaymsg -t get_outputs | \
        jq -e 'length==1' && \
        swaymsg workspace back_and_forth || \
        swaymsg focus output right
    bindsym $alt+$shf+Tab exec swaymsg -t get_outputs | \
        jq -e 'length==1' && \
        swaymsg move container to workspace back_and_forth || \
        swaymsg move container to output right
    bindsym $alt+grave move workspace to output right

    # special workspace commands
    bindsym $mod+$shf+bracketleft  exec swaymsg "workspace number $(swaymsg -t get_workspaces | jq -r '.. | select(.focused?).num-1 | if (10<=. and .<=90 and .%10==0)      then "$ws\(./10)" else . end')"
    bindsym $mod+$shf+bracketright exec swaymsg "workspace number $(swaymsg -t get_workspaces | jq -r '.. | select(.focused?).num+1 | if (10<=. and .<=90 and .%10==0)      then "$ws\(./10)" else . end')"
    bindsym $mod+$ctl+bracketleft  exec swaymsg "workspace number $(swaymsg -t get_workspaces | jq -r '.. | select(.focused?).num   | ((.-1)/10|floor) | if (1<=. and .<=9) then "$ws\(.)" else .*10 end')"
    bindsym $mod+$ctl+bracketright exec swaymsg "workspace number $(swaymsg -t get_workspaces | jq -r '.. | select(.focused?).num   | (./10+1|floor) | if (1<=. and .<=9)   then "$ws\(.)" else .*10 end')"

    # scratchpad (technically kind of a workspace)
    bindsym $mod+$shf+minus      move scratchpad
    bindsym $mod+minus                scratchpad show
    bindsym $mod+$shf+apostrophe move scratchpad
    bindsym $mod+apostrophe           scratchpad show

#
# Layout stuff:
#
    # splits
    bindsym $mod+c exec swaymsg -t get_tree | \
        jq -e '.. | select([.nodes?[]?.focused] | any).type=="workspace"' && \
        swaymsg 'focus parent; layout toggle splith splitv; focus child' || \
        swaymsg 'layout toggle splith splitv'
    bindsym $mod+r exec swaymsg -t get_tree | \
        jq -e '.. | select([.nodes?[]?.focused] | any).type=="workspace"' && \
        swaymsg 'focus parent; layout toggle tabbed stacking; focus child' || \
        swaymsg 'layout toggle tabbed stacking'
    bindsym $mod+$ctl+c exec swaymsg -t get_tree | \
        jq -e '.. | select([.nodes?[]?.focused] | any).type=="workspace"' && \
        swaymsg 'focus parent; layout toggle splitv splith; focus child' || \
        swaymsg 'layout toggle splitv splith'
    bindsym $mod+$ctl+r exec swaymsg -t get_tree | \
        jq -e '.. | select([.nodes?[]?.focused] | any).type=="workspace"' && \
        swaymsg 'focus parent; layout toggle stacking tabbed; focus child' || \
        swaymsg 'layout toggle stacking tabbed'
    bindsym $mod+l split none
    bindsym $mod+$shf+l [all] split none
    bindsym $mod+w splith
    bindsym $mod+v splitv
    bindsym $mod+$shf+w split t; layout tabbed
    bindsym $mod+$shf+v split t; layout stacking

    # fullscreen
    bindsym $mod+f fullscreen
    bindsym $mod+u fullscreen

    # parent/child
    bindsym $mod+a focus parent
    bindsym $mod+$shf+a focus child
    bindsym $mod+g focus parent
    bindsym $mod+$shf+g focus child

#
# Resizing containers:
#
    bindsym $mod+$shf+r mode "resize"
    mode "resize" {
        bindsym $left resize shrink width 10px
        bindsym $down resize grow height 10px
        bindsym $up resize shrink height 10px
        bindsym $right resize grow width 10px
        bindsym Left resize shrink width 10px
        bindsym Down resize grow height 10px
        bindsym Up resize shrink height 10px
        bindsym Right resize grow width 10px

        bindsym $mod+$shf+r mode default
        bindsym $mod+r mode default
        bindsym Return mode default
        bindsym Escape mode default
        bindsym BackSpace mode default
        bindsym $ctl+bracketleft mode default
    }

#
# Application binds
#
    bindsym $mod+$alt+b      exec ~/.config/sway/bin/bluetooth_mark.sh
    bindsym $mod+$alt+d      exec discord --enable-features=UseOzonePlatform --ozone-platform=wayland
    bindsym $mod+$alt+$shf+d exec deluge-gtk
    bindsym $mod+$alt+f      exec env MOZ_ENABLE_WAYLAND=1 firefox
    bindsym $mod+$alt+$shf+f exec env MOZ_ENABLE_WAYLAND=1 firefox --private-window
    bindsym $mod+$alt+g      exec gimp
    bindsym $mod+$alt+$shf+g exec $cmd_secure
    bindsym $mod+$alt+n      exec ~/.config/sway/bin/mynoise_mark.sh
    bindsym $mod+$alt+s      exec signal-desktop
    bindsym $mod+$alt+$shf+s exec steam --disable-gpu -cef-disable-gpu -no-cef-sandbox
    bindsym $mod+$alt+t      exec thunar
    bindsym $mod+$alt+v      exec ~/.config/sway/bin/volume_mark.sh
    bindsym $mod+$alt+$shf+v exec pavucontrol

    # edit configs quickly
    set $mode_cfg "configs: dsStTvzZ"
    bindsym $mod+$alt+c      mode $mode_cfg
    mode $mode_cfg {
        bindsym d      exec $term -D ~/Dotfiles , mode default
        bindsym s      exec $term -T 'nvim sway config' nvim ~/.config/sway/config , mode default
        bindsym $shf+s exec $term -T 'nvim -d sway config-*' nvim -d ~/.config/sway/config.d/host-include-* , mode default
        bindsym t      exec $term -T 'nvim todo.txt' nvim ~/Dotfiles/extras/todo.txt , mode default
        bindsym $shf+t exec $term -T 'nvim todo config' nvim ~/.todo/config , mode default
        bindsym v      exec $term -T 'nvim vimrc' nvim ~/.config/nvim/init.vim , mode default
        bindsym z      exec $term -T 'nvim zshrc' nvim ~/.zshrc, mode defaultrc
        bindsym $shf+z exec $term -T 'nvim zshrc' nvim ~/.zshenv , mode default

        bindsym $mod+$alt+c mode default
        bindsym Return mode default
        bindsym Escape mode default
        bindsym BackSpace mode default
        bindsym $ctl+bracketleft mode default
    }

#
# Utilities:
#
    # special keys to adjust volume via pulseaudio
    set $vol_sig && pkill -SIGRTMIN+1 i3blocks
    bindsym --locked XF86AudioMute        exec pactl set-sink-mute   \@DEFAULT_SINK@   toggle $vol_sig
    bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@   -5%    $vol_sig
    bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@   +5%    $vol_sig
    bindsym --locked XF86AudioMicMute     exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle $vol_sig

    # special keys to adjust brightness via brightnessctl
    set $bright_sig && pkill -SIGRTMIN+2 i3blocks
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%- $bright_sig
    bindsym --locked XF86MonBrightnessUp   exec brightnessctl set 5%+ $bright_sig

    # take screenshots
    bindsym --release Print exec ~/.config/sway/bin/screenshot.sh
    bindsym $mod+p          exec ~/.config/sway/bin/screenshot.sh
    bindsym $mod+$shf+p     exec ~/.config/sway/bin/screenshot.sh

    bindsym $mod+z      exec makoctl dismiss
    bindsym $mod+$shf+z exec makoctl restore
    bindsym $mod+$ctl+z exec makoctl dismiss --all

    # media playback keys
    set $player $(playerctl -l | head -n1)
    set $player_notify ~/.config/sway/bin/playerctl_notify.zsh
    set $player_volume $((100*$(playerctl -p $player volume)))
    bindsym --locked XF86AudioPlay   exec playerctl -p $player play-pause
    bindsym --locked XF86AudioPause  exec playerctl -p $player play-pause
    bindsym --locked XF86AudioPrev   exec playerctl -p $player previous   && $player_notify
    bindsym --locked XF86AudioNext   exec playerctl -p $player next       && $player_notify
    bindsym --locked XF86AudioStop   exec playerctl -p $player stop
    bindsym --locked $mod+equal      exec $player_notify
    bindsym --locked $mod+slash      exec playerctl -p $player play-pause
    bindsym --locked $mod+$shf+slash exec playerctl -p $player previous   && $player_notify
    bindsym --locked $mod+$shf+equal exec playerctl -p $player next       && $player_notify
    bindsym --locked $mod+$alt+slash exec zsh -c '[[ $player_volume -le 0   ]] || playerctl -p $player volume 0.1-'
    bindsym --locked $mod+$alt+equal exec zsh -c '[[ $player_volume -ge 100 ]] || playerctl -p $player volume 0.1+'
    bindsym --locked $mod+$ctl+slash exec playerctld   shift && $player_notify
    bindsym --locked $mod+$ctl+equal exec playerctld unshift && $player_notify

    # locate cursor
    bindsym $mod+semicolon exec ~/Working/swaywm/git/wl-find-cursor-reticle/target/release/wl-reticle

    # gaming crosshair
    bindsym $mod+Home exec wlcrosshairctl toggle
    bindsym $mod+End  exec wlcrosshairctl reload

#
# Status Bar:
#
    bar {
        tray_output none
        font pango:$font
        position top
        status_command i3blocks
        separator_symbol " ⟨ "
        strip_workspace_numbers $strip_workspace_numbers
        colors {
            background #323232
            statusline #ffffff
            separator #ff8cda
            binding_mode #5cccb8 #8cdaff #000000
            #                  border  bckgrn  text
            focused_workspace  #e667be #ff8cda #000000
            inactive_workspace #666666 #323232 #ffffff
            urgent_workspace   #ff9933 #ffc68c #000000
        }
    }
