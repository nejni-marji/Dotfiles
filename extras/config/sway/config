#
# ~/.config/sway/config
#

### TABLE OF CONTENTS
#   * Variables
#   * Autostart
#   * Output configuration
#     * Themeing
#   * Input configuration
#   * Key bindings
#     * Basics
#     * Movement
#     * Workspace bindings
#       * Workspace configs
#     * Layout bindings
#     * Application bindings
#   * Resizing
#   * Status bar

#
### Variables
#
    # modifier keys
    set $mod Mod4
    set $alt Mod1
    set $float space
    # direction keys
    set $left h
    set $down t
    set $up n
    set $right s
    # preferred executables
    set $term foot
    set $menu exec rofi -show run

include /etc/sway/config-vars.d/*

#
### Autostart
#
    # redshift
    exec wlsunset -t 4000 -T 6500 -s 21:00 -S 7:00
    # notification server
    exec swaync
    # video wallpaper
    set $video_wallpaper ~/Downloads/fish-aquarium.1920x1080.mp4
    # this is stupid... but it works!
    exec bash -c "pkill mpvpaper ; mpvpaper HDMI-A-1 --fork --mpv-options 'loop loop-playlist' $video_wallpaper ; mpvpaper HDMI-A-2 --fork --mpv-options 'loop loop-playlist' $video_wallpaper ; sleep 0.1 ; swaymsg reload"

    # idle configuration aka powersaving aka screenlock
    exec swayidle -w \
        timeout 300 'swaylock -f -c 354045' \
        timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
        before-sleep 'swaylock -f -c 354045'

#
### Output configuration
#
    # configure output arrangement
    output HDMI-A-1 resolution 1920x1080 position 1920,0
    output HDMI-A-2 resolution 1920x1080 position 0,0

    # set wallpapers
    # we also set a video wallpaper, but this is a fallback
    output * bg /home/alex/Pictures/wizard.png fill

    # configure gaps
    set $inner 10
    set $outer 20
    smart_gaps inverse_outer
    gaps inner $inner
    gaps outer $outer
    exec_always swaymsg gaps inner all set $inner
    exec_always swaymsg gaps outer all set $outer
    bindsym $mod+$alt+g       gaps inner all set $inner ; gaps outer all set $outer
    bindsym $mod+$alt+Shift+g gaps inner all set 0      ; gaps outer all set 0

    # font
    set $font pango:Fira Code 10
    font $font

    # colors
    #       .class               border    bckgrnd   text      indctr    outline
      client.focused             #e667be   #ff8cda   #000000   #ff00ff   #ff8cda
    # client.focused_inactive    #333333   #5f676a   #ffffff   #484e50   #5f676a
    # client.focused_tab_title   #333333   #5f676a   #ffffff   #484e50   #5f676a
    # client.unfocused           #333333   #222222   #888888   #292d2e   #222222
    # client.urgent              #2f343a   #900000   #ffffff   #900000   #900000

    # miscellaneous options
    title_align center
    #titlebar_padding 20 4
    hide_edge_borders smart_no_gaps
    force_display_urgency_hint 1000

#
### Input configuration
#
    # run 'swaymsg -t get_inputs' and 'man 5 sway-input'
    input type:keyboard {
        xkb_layout us
        xkb_variant dvorak
        xkb_options caps:ctrl_modifier,caps:swapcaps,ctrl:swap_lwin_lctl,ctrl:swap_rwin_rctl
    }

    input type:pointer {
        accel_profile adaptive
        pointer_accel -0.35
    }

#
### Key bindings
#
    # Start a terminal
    bindsym $mod+Return exec $term
    bindsym $mod+Shift+Return exec $term

    # Kill focused window
    bindsym $mod+Shift+q kill

    # Start your launcher
    #bindsym $mod+d exec $menu
    bindsym $alt+Space $menu

    # Reload the configuration file
    bindsym $mod+Shift+c reload

    # Floating windows
    floating_modifier $mod normal
    bindsym $mod+Shift+$float floating toggle
    bindsym $mod+$float focus mode_toggle
    #bindsym $mod+$alt+$float sticky toggle

    # Exit sway (logs you out of your Wayland session)
    bindsym $mod+Shift+e exec swaynag -t warning \
        -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' \
        -B 'Yes, exit sway' 'swaymsg exit'

    # Take screenshots
    set $screenshot ~/Pictures/Screenshot_$(date +"%F_%H%M%S.png")
    # this is way too many bindings but i'm just covering my bases because i'm kinda dumb
    bindsym --release Print            exec grim -g "$(slurp -d)" $screenshot
    bindsym --release Shift+Print      exec grim -g "$(slurp -d)" $screenshot
    bindsym --release Ctrl+Print       exec grim -o "$(swaymsg -t get_outputs | jq '.[] | select(.focused).name' -r)" $screenshot
    bindsym --release $mod+Print       exec grim -g "$(slurp -d)" $screenshot
    bindsym --release $mod+Shift+Print exec grim -g "$(slurp -d)" $screenshot
    bindsym --release $mod+Ctrl+Print  exec grim -o "$(swaymsg -t get_outputs | jq '.[] | select(.focused).name' -r)" $screenshot

#
# Moving around:
#
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

#
# Workspaces:
#
    # workspace options
    workspace_auto_back_and_forth yes

    # set names
    set $ws1 1:main
    set $ws2 2:side
    set $ws3 3:code
    set $ws4 4:game
    set $ws5 5
    set $ws6 6
    set $ws7 7
    set $ws8 8
    set $ws9 9:bg
    set $ws0 10

    # move by number
    bindsym $mod+1 workspace number $ws1
    bindsym $mod+2 workspace number $ws2
    bindsym $mod+3 workspace number $ws3
    bindsym $mod+4 workspace number $ws4
    bindsym $mod+5 workspace number $ws5
    bindsym $mod+6 workspace number $ws6
    bindsym $mod+7 workspace number $ws7
    bindsym $mod+8 workspace number $ws8
    bindsym $mod+9 workspace number $ws9
    bindsym $mod+0 workspace number $ws0
    bindsym $mod+Shift+1 move container to workspace number $ws1
    bindsym $mod+Shift+2 move container to workspace number $ws2
    bindsym $mod+Shift+3 move container to workspace number $ws3
    bindsym $mod+Shift+4 move container to workspace number $ws4
    bindsym $mod+Shift+5 move container to workspace number $ws5
    bindsym $mod+Shift+6 move container to workspace number $ws6
    bindsym $mod+Shift+7 move container to workspace number $ws7
    bindsym $mod+Shift+8 move container to workspace number $ws8
    bindsym $mod+Shift+9 move container to workspace number $ws9
    bindsym $mod+Shift+0 move container to workspace number $ws0

    # move between workspaces and outputs
    bindsym $mod+bracketleft workspace prev_on_output
    bindsym $mod+bracketright workspace next_on_output
    bindsym $mod+BackSpace workspace back_and_forth
    bindsym $mod+Shift+BackSpace move container to workspace back_and_forth
    bindsym $alt+Tab focus output right
    #bindsym $mod+slash focus output left
    #bindsym $mod+equal focus output right

    # scratchpad (technically kind of a workspace)
    bindsym $mod+Shift+minus move scratchpad
    bindsym $mod+minus scratchpad show

#
# Layout stuff:
#
    # left-hand layout keys
    bindsym $mod+o layout toggle tabbed stacking
    bindsym $mod+comma layout split tabbed stacking
    bindsym $mod+period layout toggle split

    # right-hand layout keys
    bindsym $mod+c layout toggle split
    bindsym $mod+r layout toggle tabbed stacking
    bindsym $mod+l split none
    bindsym $mod+w splith
    bindsym $mod+v splitv
    bindsym $mod+z workspace back_and_forth

    # fullscreen
    bindsym $mod+f fullscreen
    bindsym $mod+u fullscreen

    # parent/child
    bindsym $mod+a focus parent
    bindsym $mod+Shift+a focus child
    bindsym $mod+g focus parent
    bindsym $mod+Shift+g focus child

#
# Application binds
#
    bindsym $mod+$alt+f exec env MOZ_ENABLE_WAYLAND=1 firefox
    bindsym $mod+$alt+Shift+f exec env MOZ_ENABLE_WAYLAND=1 firefox --private-window

#
# Resizing containers:
#
    bindsym $mod+Shift+r mode "resize"
    mode "resize" {
        bindsym $left resize shrink width 10px
        bindsym $down resize grow height 10px
        bindsym $up resize shrink height 10px
        bindsym $right resize grow width 10px
        bindsym Left resize shrink width 10px
        bindsym Down resize grow height 10px
        bindsym Up resize shrink height 10px
        bindsym Right resize grow width 10px

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+Shift+r mode "default"
    }

#
# Status Bar:
#
    bar {
        #TODO
        height 25
        gaps 0 10 0 10
        font $font
        position top
        #status_command while date +'%A, %B %d, %-I:%M %p   ' ; do sleep 15 ; done
        status_command i3blocks
        colors {
            statusline #ffffff
            background #323232
            #                  bckgrn  border  text
            focused_workspace  #e667be #ff8cda #ffffff
            inactive_workspace #323232 #323232 #5c5c5c
        }
    }

include /etc/sway/config.d/*
