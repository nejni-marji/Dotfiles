#
### Variables
#
	# workspace names
	set $ws1 10: chat
	set $ws2 20: web
	set $ws3 30: code
	set $ws4 40: game
	set $ws5 50: media
	set $ws6 60: docs
	set $ws7 70
	set $ws8 80
	set $ws9 90
	set $ws0 100
	# fonts and themes
	set $font ComicCode 12
	set $cursor catppuccin-latte-pink-cursors 24
	# window borders and gaps
	set $borders normal 3
	set $hide_edge_borders smart_no_gaps
	set $gaps_inner 10
	set $gaps_outer 20
	set $strip_workspace_numbers no

#
### Autostart
#
    # idle inhibitor for gaming and movies
    for_window [all] inhibit_idle fullscreen

#
### Output configuration
#
    # configure output arrangement
    output HDMI-A-1 resolution 1920x1080 position 1920,0
    output HDMI-A-2 resolution 1920x1080 position 0,0


    # default workspaces
    workspace $ws1 output HDMI-A-2
    workspace $ws2 output HDMI-A-1
    workspace $ws3 output HDMI-A-1
    workspace $ws4 output HDMI-A-1
    workspace $ws5 output HDMI-A-1
    workspace $ws6 output HDMI-A-2
    workspace $ws9 output HDMI-A-2
    workspace $ws0 output HDMI-A-2
